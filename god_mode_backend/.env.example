NODE_ENV=development
PORT=8081

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=god_mode_licensing
MYSQL_POOL_SIZE=12

REDIS_URL=redis://127.0.0.1:6379

JWT_ACCESS_SECRET=replace_with_long_random_access_secret_32_plus_chars
JWT_REFRESH_SECRET=replace_with_long_random_refresh_secret_32_plus_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Encryption key rotation (preferred)
# COMM_ACTIVE_KID must exist in both JSON maps.
COMM_ACTIVE_KID=v1
COMM_AES_KEYS_JSON={"v1":"replace_with_base64_32bytes_key","v2":"replace_with_next_base64_32bytes_key"}
COMM_HMAC_KEYS_JSON={"v1":"replace_with_long_hmac_secret_v1","v2":"replace_with_long_hmac_secret_v2"}

# Legacy single-key fallback (optional)
COMM_AES_KEY_B64=replace_with_base64_32bytes_key
COMM_HMAC_SECRET=replace_with_long_hmac_secret

MAX_CLOCK_SKEW_SECONDS=120
NONCE_TTL_SECONDS=300

VERIFY_RATE_LIMIT_PER_MIN=120
VERIFY_FAIL_WINDOW_SECONDS=600
VERIFY_FAIL_MAX_PER_IP=50
VERIFY_FAIL_MAX_PER_KEY=35
VERIFY_FAIL_MAX_PER_HWID=30
AUTO_BAN_IP_FAIL_THRESHOLD=120
AUTO_BAN_IP_DURATION_SECONDS=3600

# Basic admin login anomaly detector (network prefix change sensitivity)
ADMIN_IP_ANOMALY_DISTANCE=1

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeMeStrong123!
SEED_ADMIN_ROLE=owner

# Payment/Webhook integration
PAYMENT_WEBHOOK_SECRET=replace_with_payment_webhook_secret
PAYMENT_DEFAULT_DURATION_DAYS=30
PAYMENT_LICENSE_PREFIX=PAY
CUSTOMER_PORTAL_TOKEN_TTL_HOURS=72

# Comma-separated list, empty allows no browser origin
CORS_ORIGINS=http://localhost:5173
