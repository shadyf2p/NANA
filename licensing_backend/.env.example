NODE_ENV=development
PORT=8080

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=licensing_db
DB_CONN_LIMIT=10

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=2h

# CORS: comma-separated allowlist, e.g. http://localhost:5173,https://admin.example.com
CORS_ORIGINS=http://localhost:5173

# Seed first admin at startup if username doesn't exist
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=ChangeThisStrongPassword!

# Verification abuse controls
VERIFY_FAIL_WINDOW_SECONDS=600
VERIFY_FAIL_MAX_PER_IP=40
VERIFY_FAIL_MAX_PER_HWID=25
VERIFY_FAIL_MAX_PER_KEY=25

# Optional hard limit by IP for /api/key/verify
VERIFY_RATE_LIMIT_PER_MINUTE=120
